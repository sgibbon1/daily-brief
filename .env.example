# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Notre Dame Gmail (alumni.nd.edu) ──────────────────────────────────────────
# Your full ND alumni address
ND_EMAIL_ADDRESS=yourname@alumni.nd.edu
# From Google Cloud Console → Google Auth Platform → Clients → daily-brief
ND_GMAIL_CLIENT_ID=297790329302-xxxx.apps.googleusercontent.com
ND_GMAIL_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxx

# ── Johns Hopkins (alumni.jh.edu) — Microsoft Graph API ──────────────────────
# From your Azure app registration (see README step 2)
JHU_EMAIL_ADDRESS=yourname@alumni.jh.edu
JHU_AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
JHU_AZURE_TENANT_ID=common
# Leave JHU_AZURE_CLIENT_SECRET blank for a public client app (recommended)
JHU_AZURE_CLIENT_SECRET=
